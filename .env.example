# Copy to .env and fill in. .env is gitignored.
# vlow auto-loads this file on startup (shell env vars take precedence).

# Transcription backend: "mlx" (local, default), "assemblyai" (cloud), or
# "auto" (route by duration — short → mlx, long → assemblyai).
VLOW_BACKEND=mlx

# Auto-mode threshold in seconds. Recordings longer than this go to
# AssemblyAI; shorter ones stay local. Only used when VLOW_BACKEND=auto.
VLOW_AUTO_THRESHOLD_SEC=60

# Required when AssemblyAI is in play (VLOW_BACKEND=assemblyai or auto).
# Get one at https://www.assemblyai.com/dashboard/api-keys
ASSEMBLYAI_API_KEY=

# Optional: ISO 639-1 language code for AssemblyAI (e.g. de, en, es).
# Unset → AssemblyAI auto-detects the language per request.
VLOW_AAI_LANGUAGE=

# Optional: print every modifier event to stdout for hotkey debugging.
# Any non-empty value enables it.
VLOW_DEBUG=
